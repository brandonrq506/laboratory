{
  "name": "laboratory",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.16.0"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "postinstall": "npm run build",
    "serve-heroku": "npx serve -s dist -l $PORT",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --report-unused-disable-directives --max-warnings 0 --fix",
    "prettier": "prettier --check \"src/**/*.{ts,tsx,html}\"",
    "prettier:fix": "prettier --write \"src/**/*.{ts,tsx,html}\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:expert": "DEBUG_PRINT_LIMIT=10000 npm run test",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "linters": "npm run prettier:fix && npm run lint:fix && npm run type-check && npm run test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.17.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.76.1",
    "serve": "^14.2.5",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@hookform/devtools": "^4.4.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tanstack/eslint-plugin-query": "^5.101.0",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/ui": "^4.0.12",
    "baseline-browser-mapping": "^2.10.34",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.0.0-beta-714736e-20250131",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-testing-library": "^7.15.4",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "jsdom-testing-mocks": "^1.16.0",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.0.12"
  }
}
